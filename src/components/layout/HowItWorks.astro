---
// HowItWorks Component - Process section showing 4 steps to digital dominance
// Features responsive grid, connector lines, and premium hover effects

export interface Props {
  eyebrow?: string;
  heading?: string;
  subheading?: string;
}

const {
  eyebrow = "OUR PROCESS",
  heading = "Four steps to a dominant digital presence",
  subheading = "From browsing to launching, we guide you through every step of your digital transformation.",
} = Astro.props;

const steps = [
  {
    number: "01",
    icon: "browse",
    title: "Browse the Library",
    description:
      "Explore our collection of high-performance templates specifically built for Plumbing and HVAC contractors.",
  },
  {
    number: "02",
    icon: "choose",
    title: "Choose Your Blueprint",
    description:
      "Select the layout that fits your business model, whether you focus on emergency repairs or commercial installs.",
  },
  {
    number: "03",
    icon: "connect",
    title: "Connect to the Team",
    description:
      "Work with our experts to integrate your branding, logos, and specific service areas into the template.",
  },
  {
    number: "04",
    icon: "launch",
    title: "Launch & Scale",
    description:
      "Go live with a lightning-fast site designed to capture leads and grow your digital presence immediately.",
  },
];

const iconPaths: Record<string, string> = {
  browse:
    "M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4",
  choose:
    "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  connect:
    "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z",
  launch:
    "M13 10V3L4 14h7v7l9-11h-7z",
};
---

<section class="py-20 md:py-32 px-6 bg-white">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center mb-16 md:mb-20">
      <span
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        {eyebrow}
      </span>
      <h2 class="heading-primary mt-4 mb-4">{heading}</h2>
      <p class="text-lg text-[#7E7E7E] max-w-2xl mx-auto leading-relaxed">
        {subheading}
      </p>
    </div>

    <!-- Steps Grid with Connector Lines -->
    <div class="relative">
      <!-- Horizontal Connector Line (Desktop Only) -->
      <div
        class="hidden lg:block absolute top-24 left-0 right-0 h-1 bg-gradient-to-r from-[#F48C06] via-[#1B4D7E] to-[#F48C06]"
        style="z-index: 0;"
      >
      </div>

      <!-- Steps Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative" style="z-index: 1;">
        {
          steps.map((step, index) => (
            <div class="group">
              <!-- Step Card -->
              <div class="text-center">
                <!-- Icon Container with Step Number -->
                <div class="relative mb-6 flex justify-center">
                  <!-- Main Icon Circle -->
                  <div
                    class="w-32 h-32 rounded-2xl flex items-center justify-center transition-all duration-300 group-hover:shadow-xl group-hover:-translate-y-2 relative"
                    style="background: linear-gradient(135deg, var(--helios-orange), #ff6b35);"
                  >
                    <svg
                      class="w-16 h-16 text-white transition-transform duration-300 group-hover:scale-110"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.5"
                        d={iconPaths[step.icon] || iconPaths.browse}
                      />
                    </svg>

                    <!-- Step Number Badge -->
                    <div
                      class="absolute -top-2 -right-2 w-12 h-12 rounded-full flex items-center justify-center font-bold text-white text-sm transition-all duration-300 group-hover:scale-110"
                      style="background: linear-gradient(135deg, var(--steel-blue), #1B4D7E);"
                    >
                      {step.number}
                    </div>
                  </div>
                </div>

                <!-- Content -->
                <h3 class="text-xl md:text-2xl font-bold text-[#0A1931] mb-3 group-hover:text-[#F48C06] transition-colors duration-300">
                  {step.title}
                </h3>
                <p class="text-[#7E7E7E] leading-relaxed text-sm md:text-base">
                  {step.description}
                </p>

                <!-- Decorative Bottom Line -->
                <div
                  class="mt-6 h-1 w-12 mx-auto rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300"
                  style="background: linear-gradient(to right, var(--helios-orange), var(--steel-blue));"
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>