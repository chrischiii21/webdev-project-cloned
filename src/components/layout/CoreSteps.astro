---
// CTA Section Component - Shows the workflow/process in a visual timeline
// Reusable across multiple pages
import Card from "../ui/Card.astro";

export interface Props {
  title?: string;
  highlightWord?: string;
  description?: string;
  steps?: Array<{
    number: number;
    title: string;
    description: string;
    icon?: string;
  }>;
}

const {
  title = "How It Works",
  highlightWord = "Works",
  description = "Our proven process gets your business online and generating leads in no time.",
  steps = [
    {
      number: 1,
      title: "Discovery & Planning",
      description: "We learn about your business, goals, and target audience to create a tailored strategy.",
    },
    {
      number: 2,
      title: "Design & Development",
      description: "Our team builds a stunning, conversion-focused website optimized for your industry.",
    },
    {
      number: 3,
      title: "Launch & Optimization",
      description: "We deploy your site and implement SEO, analytics, and performance tracking.",
    },
    {
      number: 4,
      title: "Growth & Support",
      description: "Ongoing support and optimization to ensure your site continues to generate leads.",
    },
  ],
} = Astro.props;

const titleParts = title.split(highlightWord);
---

<section class="py-20 md:py-32 px-4 md:px-6 lg:px-8 bg-parchment">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
       <span
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        OUR PROCESS
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-[#0A1931] mb-6 mt-4">
        {titleParts[0]}
        <span style="color: var(--helios-orange);">{highlightWord}</span>
        {titleParts[1]}
      </h2>
      <p class="text-lg text-[#7E7E7E] max-w-3xl mx-auto">
        {description}
      </p>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      {steps.map((step, index) => (
        <div class="relative h-full group">
          <!-- Step Number Circle -->
          <div class="absolute -top-6 left-6 w-12 h-12 rounded-full bg-gradient-to-br from-[#F48C06] to-[#ff6b35] flex items-center justify-center text-white font-bold text-lg shadow-lg z-10 transition-transform duration-300 group-hover:scale-110">
            {step.number}
          </div>

          <!-- Step Card using Card component -->
          <div class="h-full">
            <Card accent="orange">
              <div class="pt-2">
                <h3 class="text-xl font-bold text-[#0A1931] mb-3">
                  {step.title}
                </h3>
                <p class="text-sm text-[#7E7E7E] leading-relaxed">
                  {step.description}
                </p>
              </div>
            </Card>
          </div>

          <!-- Modern Connector (Desktop only) -->
          {index < steps.length - 1 && (
            <div class="hidden lg:flex absolute top-1/2 left-full w-8 h-12 items-center justify-center pointer-events-none transform -translate-y-1/2">
              <!-- Dotted line -->
              <div class="absolute left-0 top-1/2 w-full h-px border-t-2 border-dotted border-[#F48C06]/30"></div>
              
              <!-- Animated arrow circle -->
              <div class="relative w-6 h-6 rounded-full bg-white border-2 border-[#F48C06]/40 flex items-center justify-center shadow-sm transition-all duration-300 hover:border-[#F48C06] hover:shadow-md">
                <svg class="w-3 h-3 text-[#F48C06]" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                </svg>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-16">
      <p class="text-[#7E7E7E] mb-6">Ready to get started with your digital transformation?</p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 font-primary font-semibold border-none rounded-xl transition-all duration-300 cursor-pointer select-none focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#F48C06] disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider bg-gradient-to-br from-[var(--helios-orange)] to-[#ff6b35] text-white hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(244,140,6,0.3)] active:translate-y-0 px-8 py-4 text-base"
      >
        Start Your Project
      </a>
    </div>
  </div>
</section>
