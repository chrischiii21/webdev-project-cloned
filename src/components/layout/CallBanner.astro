---
// Call Banner Component - Urgent CTA banner
import Button from "../ui/Button.astro";

export interface Props {
    message?: string;
    phoneNumber?: string;
    subtext?: string;
    buttonText?: string;
}

const {
    message = "Don't Waste Your Time, Call Today:",
    phoneNumber = "(555) 123-4567",
    subtext = "There are many myths passed on from the greater culture.",
    buttonText = "GET YOUR QUOTE",
} = Astro.props;
---

<section
    class="py-8 md:py-12 px-4 md:px-6 lg:px-8 bg-gradient-to-br from-[#0a1931] to-[#1a2a4a]"
>
    <div class="max-w-7xl mx-auto">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-6 md:gap-8"
        >
            <!-- Left Side - Message and Phone -->
            <div class="text-center md:text-left">
                <h3 class="text-xl md:text-2xl font-bold text-white mb-2">
                    {message}
                    <a
                        href={`tel:${phoneNumber.replace(/[^0-9+]/g, "")}`}
                        class="text-[#F48C06] hover:underline transition-all duration-300"
                    >
                        {phoneNumber}
                    </a>
                </h3>
                <p class="text-sm md:text-base text-[#7E7E7E]">
                    {subtext}
                </p>
            </div>

            <!-- Right Side - CTA Button -->
            <div class="flex-shrink-0">
                <Button href="/contact" variant="primary" size="md">
                    {buttonText}
                </Button>
            </div>
        </div>
    </div>
</section>
