---
// Hero component for Buildr - Construction site style
import Button from "../ui/Button.astro";

export interface Props {
  title?: string;
  subtitle?: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  backgroundImages?: string[];
}

const {
  title = "Build. Grow. Dominate.",
  subtitle = "Your Growth Partner",
  description = "Over 2,500 contractors and trades professionals have trusted us to elevate their digital presence. Transform your business online and reach more customers than ever before.",
  buttonText = "VIEW OUR WORK",
  buttonLink = "#work",
  backgroundImages = [
    "/images/img1.avif",
    "/images/img2.avif",
    "/images/img3.avif",
    "/images/img4.avif",
    "/images/img5.avif",
  ],
} = Astro.props;
---

<section
  class="relative h-screen flex items-center overflow-hidden md:bg-transparent"
  style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--steel-blue) 20%) 100%);"
>
  <!-- Background Image Slideshow - Hidden on Mobile -->
  <div class="absolute inset-0 hidden md:block">
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-[1500ms] ease-in-out slideshow-image active"
      style="background-image: url('/images/img1.avif'); filter: brightness(0.6);"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-[1500ms] ease-in-out slideshow-image"
      style="background-image: url('/images/img2.avif'); filter: brightness(0.6);"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-[1500ms] ease-in-out slideshow-image"
      style="background-image: url('/images/img3.avif'); filter: brightness(0.6);"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-[1500ms] ease-in-out slideshow-image"
      style="background-image: url('/images/img4.avif'); filter: brightness(0.6);"
    >
    </div>
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat opacity-0 transition-opacity duration-[1500ms] ease-in-out slideshow-image"
      style="background-image: url('/images/img5.avif'); filter: brightness(0.6);"
    >
    </div>
  </div>

  <!-- Dark Overlay - Only on Desktop -->
  <div
    class="absolute inset-0 opacity-60 hidden md:block"
    style="background: linear-gradient(135deg, var(--midnight-navy) 0%, color-mix(in srgb, var(--midnight-navy) 80%, var(--steel-pewter) 20%) 100%);"
  >
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-[1280px] mx-auto px-4 md:px-8">
    <div class="space-y-8 text-left">
      <!-- Small Title -->
      <div class="animate-[fade-in_1s_ease-out]">
        <span
          class="inline-block font-semibold tracking-widest uppercase text-sm"
          style="color: var(--helios-orange);"
        >
          Your Growth Partner
        </span>
      </div>

      <!-- Main Heading -->
      <div class="space-y-4 animate-[fade-in-up_1s_ease-out]">
        <h1
          class="text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-bold leading-tight text-left"
        >
          <span class="text-white">Build. </span>
          <span style="color: var(--helios-orange);">Grow. </span>
          <span class="text-white">Dominate.</span>
        </h1>

        <p
          class="text-base md:text-lg lg:text-xl leading-relaxed max-w-2xl text-white text-left"
        >
          Over 2,500 contractors and trades professionals have trusted us to
          elevate their digital presence. Transform your business online and
          reach more customers than ever before.
        </p>
      </div>

      <!-- CTA Button -->
      <div
        class="pt-4 animate-[fade-in-up_1s_ease-out] opacity-0 [animation-delay:0.5s] [animation-fill-mode:forwards]"
      >
        <Button variant="primary" size="md" href="/our-work">
          VIEW OUR WORK
        </Button>
      </div>
    </div>
  </div>

  <!-- Slideshow Navigation Dots -->
  <div
    class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-20 flex space-x-3 hidden"
  >
    <button
      class="slideshow-dot w-3 h-3 rounded-full bg-amber-400 transition-all duration-300"
      data-slide="0"></button>
    <button
      class="slideshow-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/75 transition-all duration-300"
      data-slide="1"></button>
    <button
      class="slideshow-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/75 transition-all duration-300"
      data-slide="2"></button>
    <button
      class="slideshow-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/75 transition-all duration-300"
      data-slide="3"></button>
    <button
      class="slideshow-dot w-3 h-3 rounded-full bg-white/50 hover:bg-white/75 transition-all duration-300"
      data-slide="4"></button>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    let currentSlide = 0;
    const slides = document.querySelectorAll(".slideshow-image");
    const dots = document.querySelectorAll(".slideshow-dot");
    const totalSlides = slides.length;

    function showSlide(index: number) {
      // Remove active class from all slides and dots
      slides.forEach((slide) =>
        slide.classList.remove("active", "opacity-100"),
      );
      dots.forEach((dot) => dot.classList.remove("active"));

      // Add active class to current slide and dot
      slides[index].classList.add("active", "opacity-100");
      dots[index].classList.add("active");

      // Update dot styles
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.remove("bg-white/50");
          dot.classList.add("bg-amber-400");
        } else {
          dot.classList.remove("bg-amber-400");
          dot.classList.add("bg-white/50");
        }
      });
    }

    function nextSlide() {
      currentSlide = (currentSlide + 1) % totalSlides;
      showSlide(currentSlide);
    }

    // Auto-advance slideshow every 5 seconds
    setInterval(nextSlide, 5000);

    // Manual navigation with dots
    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentSlide = index;
        showSlide(currentSlide);
      });
    });
  });
</script>

<style>
  .slideshow-image.active {
    opacity: 1 !important;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
