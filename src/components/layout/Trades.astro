---
// Trades Section with Hover Cards
---

<section class="py-20 relative overflow-hidden bg-parchment">
  <div class="max-w-7xl mx-auto px-8 relative z-10">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span
        class="text-sm font-semibold tracking-widest uppercase"
        style="color: var(--helios-orange);"
      >
        TRADES WE SERVE
      </span>
      <h2
        class="text-4xl md:text-5xl font-bold mb-6 mt-4"
        style="color: var(--midnight-navy);"
      >
        Our <span style="color: var(--helios-orange);">Expertise</span>
      </h2>
      <p
        class="text-lg max-w-3xl mx-auto leading-relaxed"
        style="color: var(--steel-pewter);"
      >
        We specialize in creating powerful digital solutions for HVAC and
        plumbing contractors that convert visitors into customers.
      </p>
    </div>

    <!-- Trades Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full items-stretch">
      <!-- HVAC Card -->
      <a
        href="/trades-we-serve/hvac"
        class="group relative h-96 rounded-3xl overflow-hidden shadow-2xl cursor-pointer block transition-transform duration-300 hover:scale-[1.02]"
      >
        <!-- Image Background -->
        <img
          src="/images/img4.jpeg"
          alt="HVAC technician"
          class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
        />

        <!-- Overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent transition-all duration-500 group-hover:from-[var(--midnight-navy)] group-hover:via-[var(--midnight-navy)] group-hover:to-[var(--midnight-navy)]"
        >
        </div>

        <!-- Content - Default State -->
        <div
          class="absolute inset-0 p-8 flex flex-col justify-end transition-all duration-500 group-hover:opacity-0"
        >
          <div class="text-white">
            <div class="text-sm font-semibold mb-3 opacity-80">
              HVAC Services
            </div>
            <h3 class="text-3xl font-bold">Climate Control Solutions</h3>
          </div>
        </div>

        <!-- Content - Hover State -->
        <div
          class="absolute inset-0 p-8 flex flex-col justify-between opacity-0 transition-all duration-500 group-hover:opacity-100"
        >
          <div class="text-sm font-semibold text-white/80">HVAC Services</div>

          <div>
            <h3 class="text-3xl font-bold text-white mb-4">
              Heating & Cooling Excellence
            </h3>
            <p class="text-white/80 text-sm leading-relaxed mb-6">
              Professional HVAC solutions with mobile-optimized booking, local
              SEO optimization, and customer testimonials to drive year-round
              business growth.
            </p>
            <span class="text-white font-semibold underline hover:no-underline"
              >Read More</span
            >
          </div>
        </div>
      </a>
      <!-- Plumbing Card -->
      <a
        href="/trades-we-serve/plumbing"
        class="group relative h-96 rounded-3xl overflow-hidden shadow-2xl cursor-pointer block transition-transform duration-300 hover:scale-[1.02]"
      >
        <!-- Image Background -->
        <img
          src="/images/img2.jpg"
          alt="Plumber working"
          class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
        />

        <!-- Overlay -->
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent transition-all duration-500 group-hover:from-[var(--helios-orange)] group-hover:via-[var(--helios-orange)] group-hover:to-[var(--helios-orange)]"
        >
        </div>

        <!-- Content - Default State -->
        <div
          class="absolute inset-0 p-8 flex flex-col justify-end transition-all duration-500 group-hover:opacity-0"
        >
          <div class="text-white">
            <div class="text-sm font-semibold mb-3 opacity-80">
              Plumbing Services
            </div>
            <h3 class="text-3xl font-bold">Emergency Ready Solutions</h3>
          </div>
        </div>

        <!-- Content - Hover State -->
        <div
          class="absolute inset-0 p-8 flex flex-col justify-between opacity-0 transition-all duration-500 group-hover:opacity-100"
        >
          <div class="text-sm font-semibold text-black/80">
            Plumbing Services
          </div>

          <div>
            <h3 class="text-3xl font-bold text-black mb-4">
              24/7 Emergency Plumbing
            </h3>
            <p class="text-black/80 text-sm leading-relaxed mb-6">
              Emergency call capture system, service area mapping, and
              before/after galleries to showcase your reliability and capture
              urgent service requests.
            </p>
            <span class="text-black font-semibold underline hover:no-underline"
              >Read More</span
            >
          </div>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  /* Smooth transitions */
  * {
    transition-property:
      transform, box-shadow, background-color, border-color, color, opacity;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>