---

import Button from '../ui/Button.astro';
import FormInput from '../ui/FormInput.astro';
// Hero2 Component - Configurable hero section with form and background
export interface Props {
  eyebrow?: string;
  headline?: string;
  backLink?: string;
  backText?: string;
  showBackLink?: boolean;
  highlightWord?: string;
  description?: string;
  formTitle?: string;
  formButtonText?: string;
  showForm?: boolean;
  variant?: 'default' | 'centered' | 'split';
}

const { 
  eyebrow = "YOUR GROWTH PARTNER",
  headline = "Build. Grow. Dominate.",
  backLink = "/trades-we-serve",
  backText = "Back to Trades",
  showBackLink = false,
  highlightWord = "Grow",
  description = "Over 2,500 contractors and trades professionals have trusted us to elevate their digital presence. Transform your business online and reach more customers than ever before.",
  formTitle = "Get Your Free Quote Today",
  formButtonText = "Get Started",
  showForm = true,
  variant = "split"
} = Astro.props;

// Split headline into parts for highlighting
const headlineParts = headline.split(highlightWord);
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background with overlay -->
  <div class="absolute inset-0 bg-linear-to-br from-[#0D1C34] via-[#0A1931]/90 to-[#1B4D7E]/80"></div>
  
  <!-- Animated background elements -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-[#F48C06]/10 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[#99B0BB]/10 rounded-full blur-3xl animate-pulse delay-1000"></div>
  </div>

  <div class="relative z-10 w-full py-16 pt-[80px]">
    <div class="max-w-7xl mx-auto">
      
      
      {variant === 'split' ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center px-8">
          <!-- Left Content -->
          <div>   
            <!-- Back Link - Top of Section -->
            {showBackLink && backLink && (
              <div class="mb-12">
                <a
                  href={backLink}
                  class="inline-flex items-center gap-3 text-white/80 hover:text-[#F48C06] transition-all duration-300 text-base group bg-[#0A1931]/60 backdrop-blur-md px-6 py-3 rounded-full border border-[#F48C06]/20 hover:border-[#F48C06]/60 hover:shadow-lg hover:shadow-[#F48C06]/20 hover:bg-[#0A1931]/80"
                >
                  <svg
                    class="w-5 h-5 transition-transform duration-300 group-hover:-translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M15 19l-7-7 7-7"></path>
                  </svg>
                  {backText}
                </a>
              </div>
            )}         
            <div class="space-y-8">
              <!-- Eyebrow -->
              <div class="inline-block">
                <span class="text-[#F48C06] text-sm font-bold font-primary uppercase tracking-widest border-l-4 border-[#F48C06] pl-4">
                  {eyebrow}
                </span>
              </div>
              
              <!-- Dynamic Headline -->
              <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold font-primary leading-tight text-white">
                {headlineParts[0]}
                <span class="text-[#F48C06] relative">
                  {highlightWord}
                  <div class="absolute -bottom-2 left-0 w-full h-1 bg-[#F48C06] rounded-full"></div>
                </span>
                {headlineParts[1]}
              </h1>
              
              <!-- Description -->
              <p class="text-lg md:text-xl leading-relaxed font-primary text-[#99B0BB] max-w-2xl">
                {description}
              </p>
            </div>
          </div>

          <!-- Right Form -->
          {showForm && (
            <div class="flex justify-center lg:justify-end">
              <!-- SVG Clip Path Definition -->
              <svg width="0" height="0" class="absolute">
                <defs>
                    <clipPath id="customClip" clipPathUnits="objectBoundingBox">
                        <path d="M 0.040, 0.120 L 0.040, 0.120 Q 0.040, 0.050 0.120, 0.050 L 0.820, 0.050 Q 0.900, 0.050 0.900, 0.110 L 0.900, 0.180 Q 0.900, 0.200 0.920, 0.200 L 0.930, 0.200 Q 0.960, 0.200 0.960, 0.230 L 0.960, 0.870 Q 0.960, 0.950 0.880, 0.950 L 0.130, 0.950 Q 0.090, 0.950 0.090, 0.910 L 0.090, 0.870 Q 0.090, 0.850 0.070, 0.850 L 0.060, 0.850 Q 0.040, 0.850 0.040, 0.830 Z" />
                    </clipPath>
                </defs>
              </svg>

              <div class="relative w-full max-w-2xl">
                <!-- Shadow layer -->
                <div class="absolute inset-0 bg-black/10 transform translate-x-3 translate-y-3 clipped-element" style="height: 650px;"></div>
                
                <!-- Main form with custom clip path -->
                <div class="relative bg-linear-to-br from-white/98 to-[#F5F5F5]/95 backdrop-blur-sm shadow-2xl border border-[#99B0BB]/20 clipped-element" style="height: 650px;">
                  <div class="px-20 py-24 h-full flex flex-col justify-center">
                    <h2 class="text-4xl md:text-5xl font-bold font-primary mb-10 leading-tight text-center" style="color: #0A1931;">
                      {formTitle}
                    </h2>
                    
                    <form class="space-y-6 flex-1 flex flex-col justify-center" id="hero-form-2">
                      <FormInput 
                        type="text"
                        name="name"
                        placeholder="Full Name"
                        variant="dark"
                        required
                      />
                      
                      <FormInput 
                        type="email"
                        name="email"
                        placeholder="Email Address"
                        variant="dark"
                        required
                      />
                      
                      <FormInput 
                        type="tel"
                        name="phone"
                        placeholder="Phone Number"
                        variant="dark"
                        required
                      />
                      
                      <!-- Submit Button -->
                      <div class="pt-4">
                        <Button fullWidth>
                            {formButtonText}
                        </Button>
                      </div>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      ) : (
        <!-- Centered variant -->
        <div class="text-center max-w-5xl mx-auto space-y-8">
          <!-- Eyebrow -->
          <div class="inline-block">
            <span class="text-[#F48C06] text-sm font-bold font-primary uppercase tracking-widest">
              {eyebrow}
            </span>
          </div>
          
          <!-- Dynamic Headline -->
          <h1 class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold font-primary leading-tight text-white">
            {headlineParts[0]}
            <span class="text-[#F48C06] relative">
              {highlightWord}
              <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-3/4 h-1 bg-[#F48C06] rounded-full"></div>
            </span>
            {headlineParts[1]}
          </h1>
          
          <!-- Description -->
          <p class="text-xl md:text-2xl leading-relaxed font-primary text-[#99B0BB] max-w-3xl mx-auto">
            {description}
          </p>
        </div>
      )}
      
    </div>
  </div>
</section>

<script>
  // Enhanced form handling
  document.getElementById('hero-form-2')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const button = this.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = button.textContent;
    
    // Loading state
    button.textContent = 'Sending...';
    button.disabled = true;
    
    const formData = new FormData(this as HTMLFormElement);
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      timestamp: new Date().toISOString()
    };
    
    // Simulate API call
    setTimeout(() => {
      console.log('Form submitted:', data);
      
      // Success state
      button.textContent = 'Success!';
      button.classList.add('bg-green-500');
      
      // Reset after 2 seconds
      setTimeout(() => {
        button.textContent = originalText;
        button.disabled = false;
        button.classList.remove('bg-green-500');
        (this as HTMLFormElement).reset();
      }, 2000);
      
      // Show success message
      alert('Thank you! We will contact you within 24 hours.');
    }, 1000);
  });
</script>

<style>
  .clipped-element {
    clip-path: url(#customClip);
  }
</style>