---
// Contact Form Component - Modern side-by-side layout with glass morphism
import Button from "../ui/Button.astro";
import FormInput from "../ui/FormInput.astro";
---

<!-- Main Contact Section -->
<section
    class="py-20 md:py-28 px-4 md:px-6 lg:px-8 bg-linear-to-br from-[#0a1931] to-[#1a2a4a]"
>
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-stretch">
            <!-- Left Side - Content -->
            <div class="flex flex-col justify-center">
                <p
                    class="text-sm font-semibold tracking-widest uppercase mb-4 text-[#F48C06]"
                >
                    CONTACT US
                </p>
                <h1
                    class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight"
                >
                    Ready to Transform Your Online Presence?
                </h1>
                <p class="text-lg text-[#99B0BB] mb-8 leading-relaxed">
                    Whether you're looking to build a new website, improve your
                    digital marketing, or need a complete online overhaul, our
                    team is here to help you succeed.
                </p>

                <!-- Quick Contact Options -->
                <div class="space-y-6 mb-8">
                    <!-- Phone -->
                    <div class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-lg bg-[#F48C06]/10 flex items-center justify-center shrink-0 mt-1"
                        >
                            <svg
                                class="w-6 h-6 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-white mb-1">
                                Call Us
                            </h3>
                            <p class="text-[#99B0BB]">(555) 123-4567</p>
                            <p class="text-sm text-[#99B0BB]/70">
                                Mon-Fri, 9am-6pm EST
                            </p>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-lg bg-[#F48C06]/10 flex items-center justify-center shrink-0 mt-1"
                        >
                            <svg
                                class="w-6 h-6 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-white mb-1">Email</h3>
                            <p class="text-[#99B0BB]">info@buildpro.com</p>
                            <p class="text-sm text-[#99B0BB]/70">
                                Response within 24 hours
                            </p>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="flex items-start gap-4">
                        <div
                            class="w-12 h-12 rounded-lg bg-[#F48C06]/10 flex items-center justify-center shrink-0 mt-1"
                        >
                            <svg
                                class="w-6 h-6 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"
                                ></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-semibold text-white mb-1">
                                Office
                            </h3>
                            <p class="text-[#99B0BB]">123 Main Street</p>
                            <p class="text-[#99B0BB]">New York, NY 10001</p>
                        </div>
                    </div>
                </div>

                <!-- Benefits -->
                <div class="pt-8 border-t border-[#99B0BB]/20">
                    <p class="text-sm font-semibold text-white mb-4">
                        What to expect:
                    </p>
                    <ul class="space-y-3">
                        <li class="flex items-center gap-3">
                            <svg
                                class="w-5 h-5 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-[#99B0BB]"
                                >Free initial consultation</span
                            >
                        </li>
                        <li class="flex items-center gap-3">
                            <svg
                                class="w-5 h-5 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-[#99B0BB]"
                                >Customized solutions for your business</span
                            >
                        </li>
                        <li class="flex items-center gap-3">
                            <svg
                                class="w-5 h-5 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-[#99B0BB]"
                                >Dedicated support throughout your project</span
                            >
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Right Side - Form Card with Glass Morphism -->
            <div
                class="bg-white/10 backdrop-blur-md rounded-2xl p-8 md:p-10 h-full flex flex-col justify-center shadow-xl border border-white/20"
            >
                <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">
                    Send us a message
                </h2>
                <p class="text-white/80 mb-8 text-base">
                    Let's discuss how we can help grow your business
                </p>

                <form id="contactForm" class="space-y-4">
                    <FormInput
                        type="text"
                        id="name"
                        name="name"
                        placeholder="Your Name"
                        variant="glass"
                        required
                    />

                    <FormInput
                        type="email"
                        id="email"
                        name="email"
                        placeholder="Your Email"
                        variant="glass"
                        required
                    />

                    <FormInput
                        type="tel"
                        id="phone"
                        name="phone"
                        placeholder="Your Phone Number"
                        variant="glass"
                        required
                    />

                    <FormInput
                        type="select"
                        id="trade"
                        name="trade"
                        placeholder="Select your Trade"
                        options={[
                            { value: "hvac", label: "HVAC" },
                            { value: "plumbing", label: "Plumbing" },
                            { value: "other", label: "Other" },
                        ]}
                        variant="glass"
                        required
                    />

                    <FormInput
                        type="textarea"
                        id="message"
                        name="message"
                        placeholder="Tell us about your project"
                        rows={4}
                        variant="glass"
                        required
                    />

                    <!-- Submit Button -->
                    <button
                        type="submit"
                        aria-label="Submit contact form to request a free consultation"
                        class="w-full inline-flex items-center justify-center gap-2 font-primary font-semibold border-none rounded-xl transition-all duration-300 cursor-pointer select-none focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#F48C06] disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider px-10 py-5 text-lg bg-linear-to-br from-[#F48C06] to-[#ff6b35] text-white hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(244,140,6,0.3)] active:translate-y-0"
                    >
                        Get Your Free Consultation
                    </button>
                </form>

                <!-- Trust Badges -->
                <div class="mt-6 pt-6 border-t border-white/20">
                    <div class="flex items-center justify-center gap-6">
                        <div class="flex items-center gap-2">
                            <svg
                                class="w-4 h-4 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-sm text-white/80 font-medium"
                                >No credit card required</span
                            >
                        </div>
                        <div class="flex items-center gap-2">
                            <svg
                                class="w-4 h-4 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-sm text-white/80 font-medium"
                                >Free estimate</span
                            >
                        </div>
                        <div class="flex items-center gap-2">
                            <svg
                                class="w-4 h-4 text-[#F48C06]"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                                    clip-rule="evenodd"></path>
                            </svg>
                            <span class="text-sm text-white/80 font-medium"
                                >No obligation</span
                            >
                        </div>
                    </div>
                </div>

                <!-- Success Message -->
                <div
                    id="successMessage"
                    class="hidden mt-4 p-4 bg-white/20 backdrop-blur-sm border border-white/30 text-white rounded-lg text-center text-sm"
                >
                    <p class="font-semibold">Success!</p>
                    <p>We'll be in touch soon.</p>
                </div>

                <!-- Error Message -->
                <div
                    id="errorMessage"
                    class="hidden mt-4 p-4 bg-white/20 backdrop-blur-sm border border-white/30 text-white rounded-lg text-center text-sm"
                >
                    <p class="font-semibold">Please check your form</p>
                    <p>and try again.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("contactForm") as HTMLFormElement;
        const successMessage = document.getElementById("successMessage");
        const errorMessage = document.getElementById("errorMessage");

        if (form) {
            form.addEventListener("submit", function (e) {
                e.preventDefault();

                // Reset messages
                successMessage?.classList.add("hidden");
                errorMessage?.classList.add("hidden");

                // Validate form
                if (form.checkValidity() === false) {
                    errorMessage?.classList.remove("hidden");
                    return;
                }

                // Show success message
                successMessage?.classList.remove("hidden");

                // Reset form
                form.reset();

                // Hide success message after 5 seconds
                setTimeout(() => {
                    successMessage?.classList.add("hidden");
                }, 5000);
            });
        }
    });
</script>

<style>
    input::placeholder,
    textarea::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    select option {
        background-color: #0a1931;
        color: white;
    }

    input:focus,
    textarea:focus,
    select:focus {
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.1);
    }
</style>
