---
// Results Infographic - Compact metrics summary
// Displays key performance indicators in a minimal, non-redundant format

const metrics = [
  { number: "2,500+", label: "Websites Built", icon: "globe" },
  { number: "150%", label: "Lead Increase", icon: "chart" },
  { number: "4.9/5", label: "Client Rating", icon: "star" },
];

const getIcon = (type: string) => {
  const icons: Record<string, string> = {
    globe: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20H7m6-4h.01M9 20h6",
    chart: "M13 7h8m0 0v8m0-8L5.586 19.414M7 13v8m0 0H3m4 0v-4",
    star: "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z",
  };
  return icons[type] || icons.globe;
};
---

<section class="py-12 md:py-16 px-6 bg-parchment border-y border-[#E5E7EB] relative overflow-hidden">
  <div class="absolute inset-0 bg-linear-to-r from-[#F48C06]/5 via-transparent to-[#1B4D7E]/5 -z-10"></div>

  <div class="container-custom">
    <!-- Header -->
    <div class="text-center mb-10 md:mb-12">
      <span class="text-sm font-semibold tracking-widest uppercase" style="color: var(--helios-orange);">PROVEN RESULTS</span>
      <h2 class="heading-primary mt-3 mb-2">Real Impact, Real Numbers</h2>
    </div>

    <!-- Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {metrics.map((metric, index) => (
        <div class="group relative" style={`animation-delay: ${index * 0.1}s; animation: fadeIn 0.5s ease-out forwards; opacity: 0;`}>
          <div class="relative bg-white rounded-xl border border-[#E5E7EB] transition-all duration-300 overflow-hidden p-6 md:p-8 hover:border-[#F48C06] hover:shadow-lg">
            <div class="absolute inset-0 bg-linear-to-br from-[#F48C06]/5 to-[#1B4D7E]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"></div>
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-linear-to-r from-[#F48C06] to-[#1B4D7E] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>

            <!-- Icon -->
            <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4 transition-all duration-300 group-hover:scale-110" style="background: linear-gradient(135deg, var(--helios-orange), #ff6b35);">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={getIcon(metric.icon)} />
              </svg>
            </div>

            <!-- Content -->
            <div class="text-4xl md:text-5xl font-extrabold text-[#0A1931] mb-2 group-hover:text-[#F48C06] transition-colors duration-300">
              {metric.number}
            </div>
            <p class="text-sm md:text-base font-semibold text-machinist">
              {metric.label}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-10 md:mt-12">
      <p class="text-sm md:text-base text-machinist max-w-2xl mx-auto">
        Join thousands of contractors transforming their digital presence with BuildPro.
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }
</style>
