---
// Template Card Component - Reusable card for displaying website templates
export interface Props {
    href: string;
    imageSrc: string;
    imageAlt: string;
    title: string;
    description: string;
    trade: "hvac" | "plumbing";
}

const { href, imageSrc, imageAlt, title, description, trade } = Astro.props;

// Set overlay color based on trade
const textColor = trade === "hvac" ? "text-white" : "text-black";
const textOpacity = trade === "hvac" ? "text-white/80" : "text-black/80";
---

<a
    href={href}
    class="group relative overflow-hidden rounded-2xl shadow-xl cursor-pointer block transition-all duration-300 hover:scale-[1.02] hover:shadow-2xl h-[350px]"
>
    <img
        src={imageSrc}
        alt={imageAlt}
        class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
    />
    {
        trade === "hvac" ? (
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--midnight-navy)]/90 via-[var(--midnight-navy)]/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300" />
        ) : (
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--helios-orange)]/90 via-[var(--helios-orange)]/40 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-300" />
        )
    }
    <div
        class="absolute inset-0 p-6 flex flex-col justify-end opacity-0 group-hover:opacity-100 transition-all duration-300"
    >
        <h4 class={`text-xl font-bold ${textColor} mb-2`}>
            {title}
        </h4>
        <p class={`${textOpacity} text-base`}>
            {description}
        </p>
    </div>
</a>
