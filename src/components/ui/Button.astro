---
interface Props {
  variant?: "primary" | "secondary" | "ghost" | "danger";
  size?: "sm" | "md" | "lg";
  customPadding?: string;
  customTextSize?: string;
  href?: string;
  disabled?: boolean;
  fullWidth?: boolean;
  class?: string;
  ariaLabel?: string;
}

const {
  variant = "primary",
  size = "md",
  customPadding,
  customTextSize,
  href,
  disabled = false,
  fullWidth = false,
  class: className = "",
  ariaLabel,
} = Astro.props;

const baseClasses = `
  inline-flex items-center justify-center gap-2 font-primary font-semibold
  border-none rounded-xl transition-all duration-300 cursor-pointer select-none
  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#F48C06]
  disabled:opacity-40 disabled:cursor-not-allowed uppercase tracking-wider
`;

const variantClasses = {
  primary:
    "bg-gradient-to-br from-[var(--helios-orange)] to-[#ff6b35] text-white hover:bg-gradient-to-br hover:from-[#1B4D7E] hover:to-[#0A1931] hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(27,77,126,0.4)] active:translate-y-0",
  secondary:
    "bg-[#0A1931] text-white hover:bg-gradient-to-br hover:from-[var(--helios-orange)] hover:to-[#ff6b35] hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(244,140,6,0.3)] active:translate-y-0",
  ghost:
    "bg-transparent border-2 border-[#99B0BB] text-[#7E7E7E] hover:bg-[var(--helios-orange)] hover:text-white hover:border-[var(--helios-orange)] hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(244,140,6,0.2)] active:translate-y-0",
  danger:
    "bg-gradient-to-br from-red-600 to-red-700 text-white hover:bg-gradient-to-br hover:from-[#1B4D7E] hover:to-[#0A1931] hover:-translate-y-0.5 hover:shadow-[0_8px_20px_rgba(27,77,126,0.4)] active:translate-y-0",
};

const sizeClasses = {
  sm: "px-6 py-3 text-sm",
  md: "px-8 py-4 text-base",
  lg: "px-10 py-5 text-lg",
};

// Use custom sizes if provided, otherwise use preset sizes
const paddingClass =
  customPadding || sizeClasses[size].split(" ").slice(0, 2).join(" ");
const textSizeClass = customTextSize || sizeClasses[size].split(" ")[2];

const widthClass = fullWidth ? "w-full" : "";

const allClasses = [
  baseClasses,
  variantClasses[variant],
  paddingClass,
  textSizeClass,
  widthClass,
  className,
]
  .join(" ")
  .replace(/\s+/g, " ")
  .trim();

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  disabled={!href ? disabled : undefined}
  aria-disabled={disabled}
  aria-label={ariaLabel}
  class={allClasses}
>
  <slot />
</Tag>
