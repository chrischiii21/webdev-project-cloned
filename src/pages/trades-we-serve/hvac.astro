---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/layout/CTASection.astro";
import FAQ from "../../components/layout/FAQ.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import TradeFeatures from "../../components/layout/TradeFeatures.astro";
import TemplateGallery from "../../components/layout/TemplateGallery.astro";

const hvacBenefits = [
    {
        title: "Seasonal Demand Visibility",
        description:
            "Showcase heating and cooling services with seasonal promotions and availability scheduling",
    },
    {
        title: "Maintenance Plan Promotions",
        description:
            "Highlight preventive maintenance packages and service agreements to build recurring revenue",
    },
    {
        title: "Emergency Service Availability",
        description:
            "24/7 emergency HVAC service visibility with immediate response capabilities and contact options",
    },
    {
        title: "Technician Credentials Display",
        description:
            "Showcase certified technicians, licenses, and industry certifications to build customer trust",
    },
    {
        title: "Service Area Expansion",
        description:
            "Strategic local SEO optimization to capture new markets and expand your service territory",
    },
    {
        title: "Energy Efficiency Focus",
        description:
            "Promote energy-saving solutions and eco-friendly HVAC systems to attract environmentally conscious customers",
    },
];

const hvacSolutions = [
    {
        title: "Service Showcase Website",
        description: "Highlight heating, cooling, and maintenance services",
    },
    {
        title: "Maintenance Plan Management",
        description: "Online portal for customers to manage service plans",
    },
    {
        title: "Local SEO for HVAC",
        description: "Rank high for seasonal HVAC searches in your area",
    },
    {
        title: "Lead Generation Campaigns",
        description: "Targeted ads for seasonal demand periods",
    },
];
---

<BaseLayout
    title="HVAC Website Design & Templates - Professional Solutions for Contractors"
    description="Professional website templates and design services specifically for HVAC contractors. Showcase your services, manage maintenance plans, and generate leads with our specialized HVAC solutions."
>
    <main>
        <Hero2
            eyebrow="HVAC SOLUTIONS"
            headline="HVAC Services"
            highlightWord="Services"
            description="Specialized digital solutions designed specifically for HVAC contractors and service providers to grow their business and reach more customers."
            showForm={true}
            showBackLink={true}
            backLink="/trades-we-serve"
            backText="Back to Trades"
        />
        <TradeFeatures
            trade="hvac"
            title="What's Included With Our HVAC Website Design Services"
            subtitle="We implement the latest and greatest technology for all the HVAC websites we build. Your website design is in good hands with"
            benefits={hvacBenefits}
            solutionsTitle="Our HVAC Solutions"
            solutions={hvacSolutions}
        />
        <TemplateGallery trade="hvac" />
        <FAQ />
        <CTASection />
    </main>
</BaseLayout>
