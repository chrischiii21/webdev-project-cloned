---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CTASection from "../../components/layout/CTASection.astro";
import FAQ from "../../components/layout/FAQ.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import TradeFeatures from "../../components/layout/TradeFeatures.astro";
import TemplateGallery from "../../components/layout/TemplateGallery.astro";

const plumbingBenefits = [
    {
        title: "Emergency Service Visibility",
        description: "24/7 emergency service showcase with prominent contact information and instant booking capabilities"
    },
    {
        title: "Online Appointment Booking",
        description: "Streamlined scheduling system allowing customers to book services at their convenience"
    },
    {
        title: "Local SEO & Service Areas",
        description: "Optimized for local search results with clear service area coverage and location-based content"
    },
    {
        title: "Customer Reviews Integration",
        description: "Display authentic customer testimonials and reviews to build trust and credibility"
    },
    {
        title: "Mobile-First Design",
        description: "Fully responsive design optimized for customers calling from mobile devices during emergencies"
    },
    {
        title: "Service Portfolio Showcase",
        description: "Professional gallery displaying your completed work and range of plumbing services"
    }
];

const plumbingSolutions = [
    {
        title: "Professional Website Design",
        description:
            "Custom-built sites showcasing your services and expertise",
    },
    {
        title: "Emergency Service Booking",
        description: "24/7 online booking system for emergency calls",
    },
    {
        title: "Local SEO Optimization",
        description: "Dominate local search results in your service areas",
    },
    {
        title: "Customer Portal",
        description: "Track service history and manage invoices online",
    },
];
---

<BaseLayout>
    <main>
        <Hero2
            eyebrow="PLUMBING SOLUTIONS"
            headline="Plumbing Services"
            highlightWord="Services"
            description="Specialized digital solutions designed specifically for plumbing contractors and service providers to grow their business and reach more customers."
            showForm={true}
            showBackLink={true}
            backLink="/trades-we-serve"
            backText="Back to Trades"
        />
        <TradeFeatures
            trade="plumbing"
            title="What's Included With Our Plumber Website Design Services"
            subtitle="We implement the latest and greatest technology for all the plumber websites we build. Your website design is in good hands with"
            benefits={plumbingBenefits}
            solutionsTitle="Our Plumbing Solutions"
            solutions={plumbingSolutions}
        />
        <TemplateGallery trade="plumbing" />
        <FAQ />
        <CTASection />
    </main>
</BaseLayout>
